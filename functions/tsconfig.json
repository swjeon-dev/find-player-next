{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["es2020"],
    "sourceMap": true,
    // "rootDir": "./src",
    "outDir": "lib",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@common": ["../common"],
      "@common/*": ["../common/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "lib", "_common"]
}
